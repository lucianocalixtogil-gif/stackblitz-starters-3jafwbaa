# URL do MCP Turminha (mesmo link para Claude, ChatGPT, Copilot, Grok)
MCP_URL=https://eeypnycefljwkyhxttzo.supabase.co/functions/v1/mcp

# ⚠️ Turminha MCP usa OAuth 2.1 — anon key / service role / JWT comum NÃO funcionam (401).
# Professores: cole só o MCP_URL no conector da IA e aprove o login na Turminha.
# Deixe SUPABASE_KEY vazio no bridge local; o OAuth é feito no browser ao conectar.

SUPABASE_KEY=

# Aliases (opcional — mesmo aviso: não substituem OAuth no endpoint Turminha)
MCP_AUTH_TOKEN=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Bridge HTTP local (server.js) — só para dev/Copilot bridge, não para professores
PORT=3000
BRIDGE_BASE_URL=http://localhost:3000
BRIDGE_AUTH_TOKEN=

# Conector stdio
MCP_CONNECTOR_NAME=turminha-mcp
MCP_TOOLS_CACHE_TTL_MS=60000

# WebSocket opcional
MCP_WS_URL=
MCP_WS_FALLBACK_HTTP=true
MCP_WS_TIMEOUT_MS=30000

# Produção
NODE_ENV=production
CORS_ORIGIN=*
COPILOT_TOOL_NAME=mcp_supabase_connector