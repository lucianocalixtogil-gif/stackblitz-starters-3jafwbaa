# URL do MCP no Supabase
MCP_URL=https://eeypnycefljwkyhxttzo.supabase.co/functions/v1/mcp

# Token principal — escolha UM (você preenche, nunca o Copilot/Grok):
#   anon key       → endpoints públicos
#   JWT usuário    → endpoints protegidos por login
#   service role   → endpoints administrativos (só no servidor/conector)
SUPABASE_KEY=

# Aliases opcionais (se preferir nomes específicos)
MCP_AUTH_TOKEN=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Bridge HTTP (server.js)
PORT=3000
BRIDGE_BASE_URL=http://localhost:3000
BRIDGE_AUTH_TOKEN=

# Conector stdio
MCP_CONNECTOR_NAME=supabase-mcp
MCP_TOOLS_CACHE_TTL_MS=60000

# WebSocket opcional
MCP_WS_URL=
MCP_WS_FALLBACK_HTTP=true
MCP_WS_TIMEOUT_MS=30000

# Produção
NODE_ENV=production
CORS_ORIGIN=*
COPILOT_TOOL_NAME=mcp_supabase_connector